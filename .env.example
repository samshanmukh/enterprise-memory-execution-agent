# ── LLM Provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic          # anthropic | openai
LLM_MODEL=claude-sonnet-4-6

ANTHROPIC_API_KEY=your_anthropic_api_key_here

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Composio ───────────────────────────────────────────────────────────────────
COMPOSIO_API_KEY=your_composio_api_key_here

# ── Target Apps ────────────────────────────────────────────────────────────────
GITHUB_REPO_OWNER=your_github_org
GITHUB_REPO_NAME=your_github_repo

SLACK_CHANNEL_ID=C1234567890
SLACK_BOT_TOKEN=xoxb-your-bot-token

NOTION_DATABASE_ID=your_notion_database_id_here
NOTION_TOKEN=secret_your_notion_token_here

LINEAR_TEAM_ID=your_linear_team_id
LINEAR_API_KEY=lin_api_your_key_here

GMAIL_RECIPIENT=team@yourcompany.com

# ── Agent Behaviour ────────────────────────────────────────────────────────────
DRY_RUN=true                    # true = simulate Composio, false = real API calls
MAX_RETRIES=3                   # max Composio retry attempts per action
CRITIC_APPROVAL_THRESHOLD=70    # confidence score below this triggers research retry
LOG_LEVEL=INFO

# ── Dashboard ──────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
